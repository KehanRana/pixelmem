# PixelMem — example env file.
# Copy to `.env` for `docker run --env-file .env`, or export individual values
# in your shell. None of these are secrets; they're config knobs.

# ----- Backend (read at process start) -----

# Comma-separated origins allowed to call the API.
# In dev, point this at whatever ports you run the frontend on.
PIXELMEM_CORS_ORIGINS=http://localhost:3000,http://localhost:3010

# FAISS index kind: "flat" (exact, default) or "hnsw" (approximate, faster at scale).
# Switching kinds requires deleting backend/storage/faiss.index + faiss_ids.npy first.
PIXELMEM_INDEX_KIND=flat

# HNSW tuning — only matters when PIXELMEM_INDEX_KIND=hnsw.
PIXELMEM_HNSW_M=32
PIXELMEM_HNSW_EF_CONSTRUCTION=80
PIXELMEM_HNSW_EF_SEARCH=64

# ----- Frontend (BUILD-TIME, baked into the Next.js output) -----
#
# Where the browser-side rewrite proxies /api/* to. For the dockerized
# frontend, this must be passed as a `--build-arg`, not as a runtime env:
#
#   docker build --build-arg PIXELMEM_BACKEND_URL=... -t pixelmem-frontend frontend
#
# For local `npm run dev`, put this in `frontend/.env.local` instead — Next.js
# auto-loads that file at dev start.
PIXELMEM_BACKEND_URL=http://localhost:8000
